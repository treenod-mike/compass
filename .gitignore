# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!crawler/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude / local tooling
.claude-dev-helper/
.omc/
.superpowers/
# .claude/ is tracked (settings.json + commands/) — only local overrides ignored
.claude/settings.local.json
.claude/logs/

# macOS screenshots (accidental drops)
스크린샷 *.png
스크린샷 *.jpg
Screen Shot *.png
Screenshot *.png

# Sensor Tower crawler
/crawler/storageState.json
/crawler/.env
/crawler/.playwright/
/crawler/debug-screenshots/
/crawler/fixtures/discovery-*.json
/crawler/last-good-snapshot.json
/crawler/.crawler.lock
/crawler/*.har
/crawler/node_modules/
/crawler/dist/
/crawler/.vitest-cache/

# Reference / scratch directories (not part of the app build)
/gameboard-src/
/Project Compass/

# Local environment (contains AppsFlyer dev token)
.env.local
